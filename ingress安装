cat > values-public.yaml << 'EOF'
controller:
  replicaCount: 3

  electionID: ingress-controller-leader-public

  ingressClass: nginx-public

  ingressClassResource:
    enabled: true
    name: nginx-public
    default: false
    controllerValue: k8s.io/ingress-nginx-public

  # ConfigMap 自定义配置
  config:
    compute-full-forwarded-for: "true"
    enable-underscores-in-headers: "true"
    error-log-level: warn
    forwarded-for-header: X-Forwarded-For
    generate-request-id: "true"
    use-forwarded-headers: "true"
    log-format-upstream: |
      [$time_iso8601] "$request" $status $request_time
      $upstream_response_time $remote_addr
      $host $request_id "$http_user_agent"
      True-Client-Ip=$remote_addr

  service:
    enabled: true
    type: LoadBalancer
    externalTrafficPolicy: Cluster
    annotations:
      service.beta.kubernetes.io/aws-load-balancer-scheme: internet-facing
      service.beta.kubernetes.io/aws-load-balancer-type: nlb
    loadBalancerClass: service.k8s.aws/nlb

  resources:
    requests:
      cpu: 100m
      memory: 90Mi

  nodeSelector:
    kubernetes.io/os: linux

  admissionWebhooks:
    enabled: true
    failurePolicy: Fail
    port: 8443
    patch:
      enabled: true
      image:
        image: ingress-nginx/kube-webhook-certgen
        tag: v1.6.9

rbac:
  create: true

serviceAccount:
  create: true

defaultBackend:
  enabled: false
EOF


curl https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | bash

使用方法
添加 Helm 仓库：
helm repo add ingress-nginx https://kubernetes.github.io/ingress-nginx
helm repo update
创建命名空间：
kubectl create ns ingress-nginx-public
安装：
helm install ingress-nginx-public \
  ingress-nginx/ingress-nginx \
  -n ingress-nginx-public \
  --version 4.15.1 \
  -f values-public.yaml

helm upgrade ingress-nginx-public \
  ingress-nginx/ingress-nginx \
  -n ingress-nginx-public \
  --version 4.15.1 \
  -f values-public.yaml

验证：
kubectl get pods -n ingress-nginx-public
kubectl get svc -n ingress-nginx-public
kubectl get ingressclass
kubectl get secret -n ingress-nginx-public
kubectl get validatingwebhookconfigurations