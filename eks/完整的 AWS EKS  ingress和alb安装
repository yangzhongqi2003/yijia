🚀 完整生产优化版 values-backend.yaml
controller:
  replicaCount: 2

  electionID: ingress-controller-leader-backend

  ingressClass: nginx-backend

  ingressClassResource:
    enabled: true
    name: nginx-backend
    default: false
    controllerValue: k8s.io/ingress-nginx-backend

  config:
    # ---------------------------
    # 🌐 真实客户端 IP & 转发链路
    # ---------------------------
    use-forwarded-headers: "true"
    compute-full-forwarded-for: "true"
    forwarded-for-header: X-Forwarded-For
    proxy-real-ip-cidr: "0.0.0.0/0"

    # ---------------------------
    # 📊 日志增强（生产推荐）
    # ---------------------------
    log-format-upstream: |
      [$time_iso8601] request="$request"
      status=$status request_time=$request_time
      upstream_time=$upstream_response_time
      client_ip=$remote_addr
      xff="$http_x_forwarded_for"
      host="$host"
      request_id="$request_id"
      user_agent="$http_user_agent"

    error-log-level: warn

    # ---------------------------
    # ⚙️ Header & API 兼容
    # ---------------------------
    enable-underscores-in-headers: "true"
    generate-request-id: "true"

  service:
    enabled: true
    type: LoadBalancer
    externalTrafficPolicy: Cluster

    # ---------------------------
    # 🌐 AWS NLB 标准配置
    # ---------------------------
    annotations:
      service.beta.kubernetes.io/aws-load-balancer-scheme: internet-facing
      service.beta.kubernetes.io/aws-load-balancer-type: nlb

      # 🚀 推荐：跨 AZ 负载均衡
      service.beta.kubernetes.io/aws-load-balancer-cross-zone-load-balancing-enabled: "true"

      # 🚀 健康检查优化
      service.beta.kubernetes.io/aws-load-balancer-healthcheck-interval: "10"
      service.beta.kubernetes.io/aws-load-balancer-healthcheck-timeout: "5"
      service.beta.kubernetes.io/aws-load-balancer-healthcheck-healthy-threshold: "2"
      service.beta.kubernetes.io/aws-load-balancer-healthcheck-unhealthy-threshold: "3"

    # ⚠️ 关键：必须在首次创建时固定
    loadBalancerClass: service.k8s.aws/nlb

  resources:
    requests:
      cpu: 100m
      memory: 90Mi
    limits:
      cpu: 500m
      memory: 256Mi

  nodeSelector:
    kubernetes.io/os: linux

  admissionWebhooks:
    enabled: true
    failurePolicy: Fail
    port: 8443
    patch:
      enabled: true
      image:
        image: ingress-nginx/kube-webhook-certgen
        tag: v1.6.9

rbac:
  create: true

serviceAccount:
  create: true

defaultBackend:
  enabled: false
